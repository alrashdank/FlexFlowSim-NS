{
  "_metadata": {
    "name": "Bakery BK50 \u2014 Real-Data-Calibrated Benchmark",
    "source": "Babor & Hitzmann (2022), DOI: 10.17632/dhgbssb8ns.2",
    "licence": "CC BY 4.0",
    "extraction_date": "2026-03-30",
    "notes": [
      "Processing times extracted from BK50 dataset (50 product groups, 76 products)",
      "Machine assignment relaxed from fixed to substitutable routing",
      "Cost ratio 1.5:1 from Therkelsen et al. (2014) oven energy differentials",
      "Kneading speed heterogeneity NOT significant (Mann-Whitney p=0.247)",
      "Baking Oven B excluded; available for 3-server extension"
    ],
    "variant": "breakdowns_A0.99",
    "availability_target": 0.99
  },
  "stages": [
    {
      "name": "Kneading",
      "servers": [
        {
          "name": "Kneader B (fast/expensive)",
