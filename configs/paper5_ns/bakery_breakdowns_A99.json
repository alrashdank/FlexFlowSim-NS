            "std": 5.8,
            "min": 1.0
          },
          "processing_cost": 1.5,
          "idle_cost": 0.5
        },
        {
          "name": "Kneader A (slow/cheap)",
          "service_time": {
            "distribution": "normal",
            "mean": 16.7,
            "std": 6.5,
            "min": 1.0
          },
          "processing_cost": 1.0,
          "idle_cost": 0.5
        }
      ]
    },
    {
      "name": "Baking",
      "servers": [
        {
          "name": "Oven A \u2014 convection (fast/expensive)",
          "service_time": {
            "distribution": "normal",
            "mean": 36.6,
            "std": 15.2,
            "min": 5.0
          },
          "processing_cost": 1.5,
          "idle_cost": 0.5
        },
        {
          "name": "Oven C \u2014 deck (slow/cheap)",
